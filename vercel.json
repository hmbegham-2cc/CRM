{
  "buildCommand": "pnpm install && pnpm --filter @crc/db db:generate && pnpm --filter @crc/web build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
